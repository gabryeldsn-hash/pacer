# MODELO de variáveis de ambiente — NÃO coloque chaves reais aqui.
# Copie para ".env.local" para testar localmente. Em produção, os mesmos nomes
# vão no painel da Vercel (Settings > Environment Variables).

# IA (Groq) — fica só no servidor. Começa com gsk_...
GROQ_API_KEY=

# Supabase — login + banco de dados.
# A URL e a chave anon são públicas (vão ao navegador); o RLS protege os dados.
SUPABASE_URL=
SUPABASE_ANON_KEY=
